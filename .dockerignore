# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json     # optional – if you want to install fresh in container
yarn.lock             # optional

# Environment variables
.env
.env.*
!.env.example         # include example file if it exists

# Version control
.git/
.gitignore
.gitattributes

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build / distribution
dist/
build/
out/
*.tgz
*.tar.gz

# Testing / coverage
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/
__mocks__/

# IDE / editor files
.vscode/
.idea/
*.iml
.project
.classpath

# Docker files (usually not needed inside image)
Dockerfile
.dockerignore
docker-compose*.yml
.docker/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# Misc
.pnpm-store/
.eslintcache
.stylelintcache
*.log